{$DOMAIN:localhost} {
    encode zstd gzip
    header Strict-Transport-Security "max-age={$SECURE_HSTS_SECONDS:2592000}"

    @api path /api/*
    handle @api {
        reverse_proxy web:8000 {
            header_up Host {host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    @admin path /admin/*
    handle @admin {
        reverse_proxy web:8000 {
            header_up Host {host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    @static path /static/*
    handle @static {
        root * /srv
        file_server
    }

    @media path /media/*
    handle @media {
        root * /srv
        file_server
    }

    handle {
        root * /srv/site
        try_files {path} /index.html
        file_server
    }
}

www.ugunsdzesiba.lv {
    redir https://lua.lv permanent
}