# Public domain served by Caddy. Include no protocol or path.
DOMAIN=example.com

# Django
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=example.com,www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=2592000
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# PostgreSQL
POSTGRES_DB=lua_production
POSTGRES_USER=lua_app
POSTGRES_PASSWORD=replace-with-a-long-unique-password

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
MEMBERSHIP_FORM_RECIPIENT=
CONTACT_FORM_RECIPIENT=
REGISTRATION_FORM_RECIPIENT=

# Turnstile: the Vite-prefixed site key is embedded during the Caddy image build.
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Form rate limiting. One Gunicorn process is used initially; use Redis before scaling.
FORM_RATE_LIMIT_TRUST_X_FORWARDED_FOR=False